{
  "$schema": "https://raw.githubusercontent.com/nicegui-inc/nicegui/main/schema/tauri.conf.json",
  "productName": "Noema",
  "version": "0.1.0",
  "identifier": "com.noema.app",
  "build": {
    "frontendDist": "../../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": {
      "cwd": "../../frontend",
      "script": "npm run dev"
    },
    "beforeBuildCommand": {
      "cwd": "../../frontend",
      "script": "npm run build"
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Noema",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ]
  }
}
